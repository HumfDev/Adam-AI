{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Adam",
  "version": "1.0.0",
  "identifier": "com.adam.dashboard",
  "build": {
    "frontendDist": "../dashboard"
  },
  "app": {
    "windows": [
      {
        "title": "Adam",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 700,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
